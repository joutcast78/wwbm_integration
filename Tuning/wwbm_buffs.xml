  <T n="buff_name">0x1003<!--Furious--></T>
  <T n="buff_description">0x1004<!--This Sim is getting angrier by the minute. Nothing is going right.--></T>
  <T n="mood_type">Angry</T>
  <T n="mood_weight">3</T>
  <T n="visible">True</T>
</I>

