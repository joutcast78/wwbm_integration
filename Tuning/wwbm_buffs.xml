<?xml version="1.0" encoding="utf-8"?>
<!--
  wwbm_buffs.xml
  Defines all the custom moodlets (buffs) this mod adds to the game.
  Place this file in the same folder as your .ts4script file.
  
  Each buff needs:
    - A unique instance ID (made up hex number, must not clash with other mods)
    - A display name and description the player sees
    - A mood it contributes to (Angry, Uncomfortable, Bored, etc.)
    - How strongly it pulls toward that mood (mood_weight)
-->

<I c="Buff" i="buff" m="buffs.buff" n="wwbm_amph_aggression_1" s="1001">
  <!-- Level 1 aggression — mild irritability from amphetamine -->
  <L n="audio_sting_on_add">
    <U>
      <T n="sting_type">STING_GENERAL_NEGATIVE</T>
    </U>
  </L>
  <T n="buff_name">0x1001<!--Restless--></T>
  <T n="buff_description">0x1002<!--Something isn't working and it's making this Sim tense.--></T>
  <T n="mood_type">Angry</T>
  <T n="mood_weight">1</T>
  <T n="visible">True</T>
  <T n="ui_sort_order">1</T>
</I>

<I c="Buff" i="buff" m="buffs.buff" n="wwbm_amph_aggression_2" s="1003">
